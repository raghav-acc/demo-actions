{
  "info": {
    "_postman_id": "5dca7f76-9d7f-4b7d-8f77-123456789abc",
    "name": "Offline_Test",
    "description": "Sample Postman collection for GitHub Actions without SAP BTP.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "https://postman-echo.com/get?status=ok",
          "protocol": "https",
          "host": [
            "postman-echo",
            "com"
          ],
          "path": [
            "get"
          ],
          "query": [
            {
              "key": "status",
              "value": "ok"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response time is below 2000 ms', function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);",
              "});",
              "",
              "var json = pm.response.json();",
              "",
              "pm.test('Status query parameter exists', function () {",
              "    pm.expect(json.args.status).to.eql('ok');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    }
  ]
}
